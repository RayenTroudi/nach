# =================================================
# PRODUCTION ENVIRONMENT VARIABLES
# =================================================
# Copy this to .env when using production Clerk keys
# Instructions: CLERK_PRODUCTION_DEPLOYMENT.md

# ============================================
# CLERK AUTHENTICATION - PRODUCTION
# ============================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_YOUR_PRODUCTION_PUBLISHABLE_KEY_HERE
CLERK_SECRET_KEY=sk_live_YOUR_PRODUCTION_SECRET_KEY_HERE

# Production webhook secret - GET THIS FROM YOUR PRODUCTION CLERK DASHBOARD
# Go to: https://dashboard.clerk.com → Production Instance → Webhooks
# Create webhook endpoint: https://www.taleldeutchlandservices.com/api/webhooks
# Copy the signing secret and paste here
WEBHOOK_SECRET=whsec_YOUR_PRODUCTION_WEBHOOK_SECRET_HERE

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/my-learning
NEXT_PUBLIC_CLERK_AFTER_DELETE_URL=/

# ============================================
# OTHER SERVICES (Same as dev)
# ============================================
RESEND_API_KEY=your_resend_api_key_here
TDS_EMAIL_NAME=TDS - Talel Deutschland Services
TDS_EMAIL_ADDRESS=noreply@taleldeutchlandservices.com
UPLOADTHING_TOKEN=your_uploadthing_token_here
UPLOADTHING_APP_ID=your_app_id_here
UPLOADTHING_SECRET=your_uploadthing_secret_here
MONGODB_URL=mongodb+srv://username:password@cluster0.mongodb.net/?appName=Cluster0
DATABASE_NAME=nach
NEXT_PUBLIC_SERVER_URL=www.taleldeutchlandservices.com
MUX_TOKEN_ID=your_mux_token_id_here
MUX_TOKEN_SECRET=your_mux_token_secret_here
PUSHER_APP_ID=your_pusher_app_id
NEXT_PUBLIC_PUSHER_KEY=your_pusher_key
PUSHER_SECRET=your_pusher_secret
NEXT_PUBLIC_PUSHER_CLUSTER=eu
